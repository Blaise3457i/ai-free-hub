rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "ublaise775@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, maxLen) {
      return request.resource.data[field] is string && request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidTool(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() < 2000 &&
             data.link is string && data.link.size() < 500;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && 
                    hasOnlyAllowedFields(['email', 'role', 'createdAt']) &&
                    request.resource.data.role == 'user';
      allow update: if isAdmin();
    }

    match /seo_pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /page_views/{viewId} {
      allow read: if isAdmin();
      allow write: if true;
    }

    match /blogs/{blogId} {
      allow read: if true; // We will filter published status in the query
      allow write: if isAdmin();
    }

    match /tools/{toolId} {
      allow read: if true; // We will filter published status in the query
      allow write: if isAdmin() && isValidTool(request.resource.data);
    }

    match /prompts/{promptId} {
      allow read: if true; // We will filter published status in the query
      allow write: if isAdmin();
    }

    match /tutorials/{tutorialId} {
      allow read: if true; // We will filter published status in the query
      allow write: if isAdmin();
    }

    match /media/{mediaId} {
      allow read, write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /analytics_daily/{date} {
      allow read: if isAdmin();
      allow write: if true; // Publicly writable for tracking
    }

    match /analytics_global/{id} {
      allow read: if isAdmin();
      allow write: if true; // Publicly writable for tracking
    }

    match /analytics_pages/{path} {
      allow read: if isAdmin();
      allow write: if true; // Publicly writable for tracking
    }
  }
}
