{
  "entities": {
    "Tool": {
      "title": "AI Tool",
      "description": "An artificial intelligence tool in the directory.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "isFree": { "type": "boolean" },
        "image": { "type": "string" },
        "imageAlt": { "type": "string" },
        "link": { "type": "string" },
        "published": { "type": "boolean" },
        "featured": { "type": "boolean" },
        "seo": {
          "type": "object",
          "properties": {
            "metaTitle": { "type": "string" },
            "metaDescription": { "type": "string" },
            "metaKeywords": { "type": "string" }
          }
        }
      },
      "required": ["name", "description", "category", "link", "image"]
    },
    "Prompt": {
      "title": "AI Prompt",
      "description": "A curated prompt for AI models.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "category": { "type": "string" },
        "badge": { "type": "string" },
        "published": { "type": "boolean" }
      },
      "required": ["text", "category"]
    },
    "Tutorial": {
      "title": "AI Tutorial",
      "description": "A guide or tutorial on using AI tools.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "published": { "type": "boolean" }
      },
      "required": ["title", "description", "category"]
    },
    "Blog": {
      "title": "Blog Post",
      "description": "A blog post or article.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "thumbnail": { "type": "string" },
        "published": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    },
    "PageSEO": {
      "title": "Page SEO",
      "description": "SEO settings for a specific page.",
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "metaKeywords": { "type": "string" },
        "canonicalURL": { "type": "string" },
        "openGraphTitle": { "type": "string" },
        "openGraphDescription": { "type": "string" },
        "openGraphImage": { "type": "string" },
        "robotsIndex": { "type": "boolean" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["path", "metaTitle", "metaDescription"]
    }
  },
  "firestore": {
    "/tools/{toolId}": {
      "schema": "Tool",
      "description": "Collection of AI tools."
    },
    "/prompts/{promptId}": {
      "schema": "Prompt",
      "description": "Collection of AI prompts."
    },
    "/tutorials/{tutorialId}": {
      "schema": "Tutorial",
      "description": "Collection of AI tutorials."
    },
    "/blogs/{blogId}": {
      "schema": "Blog",
      "description": "Collection of blog posts."
    },
    "/seo_pages/{pageId}": {
      "schema": "PageSEO",
      "description": "Collection of page-specific SEO settings."
    }
  }
}
